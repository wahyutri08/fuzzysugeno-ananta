# ======================================
# Disable directory listing
# ======================================
Options -Indexes

# ======================================
# Enable rewrite
# ======================================
RewriteEngine On

RewriteRule ^product_name/edit/([0-9]+)$ product_name/edit.php?id_product=$1 [L,QSA]
RewriteRule ^product_name/delete/([0-9]+)$ product_name/delete.php?id_product=$1 [L,QSA]
RewriteRule ^all_data/edit/([0-9]+)$ all_data/edit.php?id_stock=$1 [L,QSA]
RewriteRule ^all_data/delete/([0-9]+)$ all_data/delete.php?id_stock=$1 [L,QSA]
RewriteRule ^user_management/edit/([0-9]+)$ user_management/edit.php?id=$1 [L,QSA]
RewriteRule ^user_management/delete/([0-9]+)$ user_management/delete.php?id=$1 [L,QSA]
RewriteRule ^master_data/siswa/edit_siswa/([0-9]+)$ master_data/siswa/edit_siswa.php?id_siswa=$1 [L,QSA]
RewriteRule ^master_data/siswa/delete_siswa/([0-9]+)$ master_data/siswa/delete_siswa.php?id_siswa=$1 [L,QSA]
RewriteRule ^master_data/penilaian/edit_nilai/([0-9]+)$ master_data/penilaian/edit_nilai.php?id_siswa=$1 [L,QSA]
RewriteRule ^master_data/penilaian/delete_nilai/([0-9]+)$ master_data/penilaian/delete_nilai.php?id_siswa=$1 [L,QSA]
RewriteRule ^master_data/variabel/edit_variabel/([0-9]+)$ master_data/variabel/edit_variabel.php?id_variabel=$1 [L,QSA]
RewriteRule ^master_data/variabel/delete_variabel/([0-9]+)$ master_data/variabel/delete_variabel.php?id_variabel=$1 [L,QSA]
RewriteRule ^fuzzy_sugeno/himpunan_fuzzy/edit/([0-9]+)$ fuzzy_sugeno/himpunan_fuzzy/edit.php?id_set=$1 [L,QSA]

# ======================================
# Remove .php extension
# ======================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]

# ======================================
# Redirect index.php
# ======================================
RewriteCond %{THE_REQUEST} \s/index\.php [NC]
RewriteRule ^index\.php$ / [R=301,L]

# ======================================
# Protect sensitive files
# ======================================
RewriteRule ^config/ - [F,L]
RewriteRule ^\.env - [F,L]
RewriteRule ^composer\.(json|lock)$ - [F,L]
RewriteRule ^\.git - [F,L]

<Files .htaccess>
Order Allow,Deny
Deny from all
</Files>

# ======================================
# Security headers
# ======================================
<IfModule mod_headers.c>
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "SAMEORIGIN"
Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ======================================
# Error pages
# ======================================
ErrorDocument 403 /app-stock-edc/error/error-403.html
ErrorDocument 404 /app-stock-edc/error/error-404.html
ErrorDocument 500 /app-stock-edc/error/error-500.html